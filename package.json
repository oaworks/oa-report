{
  "name": "oareport",
  "version": "1.0.0",
  "description": "",
  "main": ".eleventy.js",
  "scripts": {
    "start": "npm run clean && concurrently \"eleventy --serve --port=8080\" \"npm run minify-css -- --watch\" \"npm run minify-js -- --watch\"",
    "clean": "rm -rf dist",
    "build": "ELEVENTY_PRODUCTION=true eleventy && NODE_ENV=production npm run minify-css && npm run minify-js",
    "minify-js": "mkdir -p dist/js && esbuild src/js/main.js --bundle --minify --format=esm --target=es2018 --outfile=dist/js/main.min.js",
    "minify-css": "npx tailwindcss -i styles/input.css -c styles/tailwind.config.js -o dist/tailwind.css --minify"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@floating-ui/dom": "^1.8.0",
    "@phosphor-icons/web": "^2.1.1",
    "@tryghost/content-api": "^1.12.10",
    "concurrently": "^10.0.3",
    "dompurify": "3.4.11",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "html-minifier-terser": "^7.2.0",
    "luxon": "^3.7.2",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it": "^14.3.0",
    "sal.js": "^0.8.5",
    "tailwindcss": "^3.4.19"
  }
}
