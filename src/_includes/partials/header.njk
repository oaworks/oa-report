{%- from "system/component.njk" import component -%}

{% set isReportPage = org and org._source and org._source.name %}
{% set isMarketingHeader = not isReportPage %}

<header class="z-50{% if page.url == '/' %} drop-shadow-md h-auto lg:sticky top-0{% endif %}">
  <span class="sr-only">
    OA.Report
  </span>
  {% if isMarketingHeader %}
    {% set nav_styles = 'py-3 md:py-4 lg:py-5 bg-neutral-100 text-neutral-900' %}
  {% else %}
    {% set nav_styles = 'py-2 md:py-3' %}
  {% endif %}
  <nav class="mx-auto flex max-w-10xl items-start sm:items-center justify-between gap-4 px-3 md:px-4 {{ nav_styles }}" aria-label="Primary navigation">

    {% if isMarketingHeader %}
    <div class="flex items-center gap-3 shrink-0">
      <a href="/" class="-mb-2 p-1 flex items-center">
        {% set logo_size = 'w-28 md:w-40 lg:w-48' %}
        {% include 'partials/app-name.njk' %}
      </a>
    </div>
    {% endif %}

    {% if isReportPage %}
    <div class="flex-1 min-w-0 flex items-center pr-2">
      <h1 class="flex min-w-0 flex-col items-start gap-1 leading-tight text-left sm:flex-row sm:items-center sm:gap-3">
        <span class="inline-flex min-w-0 max-w-full items-center gap-2">
          <span aria-hidden="true" class="w-4 h-4 rounded-full bg-carnation-500 flex-none"></span>
          {% set env = (site.base_url or '') | lower %}
          {% set envPrefix = '[STG] ' if 'staging.oa.report' in env or 'stg.oa.report' in env else ('[DEV] ' if 'dev.oa.report' in env or 'localhost' in env or '127.0.0.1' in env else '') %}
          <span class="min-w-0 max-w-full break-words font-serif font-semibold text-base md:text-lg lg:text-xl sm:truncate" title="{{ org._source.name }}">{% if envPrefix %}{{ envPrefix }}{% endif %}{{ org._source.name }}</span><span class="sr-only">’s OA.Report:</span>
        </span>
        <span class="sr-only">
          <span class="report_readable_start_date"></span>
          to
          <span class="report_readable_end_date"></span>,
        </span>
        {# a11y: Filter context for screen readers, i.e. number of filters applied #}
        <span id="js-filter-context-heading" class="sr-only" hidden></span>
      </h1>
    </div>
    {% else %}
    <div class="flex-1"></div>
    {% endif %}

    <!-- Hamburger Button -->
    <button id="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" class="sm:hidden {% if isReportPage %}hidden{% endif %} flex items-center justify-center p-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-carnation-500">
      {% icon_small "menu" %}
      <span id="menu-toggle-label" class="sr-only">Open menu</span>
    </button>

    <!-- Menu Items -->
    <div id="mobile-menu" class="hidden absolute top-full left-0 w-full sm:static sm:flex sm:items-center sm:justify-end sm:w-auto sm:bg-transparent sm:p-0">
      <div class="flex flex-col sm:flex-row sm:items-center gap-x-3 sm:gap-x-6 md:gap-x-8">
        {% if isMarketingHeader %}
        <a href="https://about.oa.report/" class="text-[11px] md:text-xs lg:text-sm font-medium leading-6 px-4 py-2 sm:p-0">About</a>
        <a href="https://blog.oa.works/join-the-oa-report-for-libraries-pilot-to-simplify-compliance-checking-for-your-institutional-funders-oa-policies/" target="_blank" class="text-[11px] md:text-xs lg:text-sm font-semibold leading-6 px-4 py-2 sm:p-0">For libraries</a>
        <a href="https://savvycal.com/Joe/ed52a37f" data-savvycal-embed class="inline-block bg-carnation-600 text-white text-[11px] md:text-xs lg:text-sm p-2 md:rounded-sm hover:bg-carnation-500 transition-all duration-300 ease-in-out transform md:hover:scale-105 focus:outline-none focus:ring-4 focus:ring-carnation-200 font-semibold px-4 py-2">
          Schedule a demo
        </a>
        {% endif %}
      </div>
    </div>
  </nav>

  {% if isReportPage %}
  <nav aria-labelledby="report-nav-heading">
    <h2 id="report-nav-heading" class="sr-only">Report navigation</h2>
    <section class="grid grid-cols-1 md:grid-cols-[1fr_auto] md:items-start gap-y-3 md:gap-y-4 md:gap-x-3 px-3 md:px-4 py-2 md:py-3">

      {# Year buttons — desktop: col 1 row 1; mobile: row 1 #}
      <div class="md:col-start-1 md:row-start-1">
        <h3 class="sr-only">View this report by year or by custom date range</h3>
        <div id="js-year-buttons" class="flex flex-wrap md:flex-nowrap gap-1.5"></div>
      </div>

      {# Active filter chips — desktop: full-width row 2; mobile: row 2 (before section tabs) #}
      <div id="report-filters" class="md:col-span-2 md:row-start-2">
        <div
          class="js-active-filters-wrapper invisible opacity-0 pointer-events-none"
          id="js-active-filters-wrapper"
          aria-labelledby="js-active-filters-title"
          aria-hidden="true"
        >
          <h3 id="js-active-filters-title" class="sr-only">Active filters</h3>
          {# Live region so SR users hear updates when filters change #}
          <div
            id="js-active-filters"
            class="flex flex-wrap items-center gap-2"
            role="status"
            aria-live="polite"
            aria-atomic="true"
          ></div>
        </div>
      </div>

      {# Section tabs — desktop: col 2 row 1 (same line as year buttons); mobile: row 3 (after filters) #}
      <div class="flex flex-wrap gap-1.5 md:flex-nowrap md:col-start-2 md:row-start-1">
        <a id="section-tab-insights" class="inline-flex items-center border border-neutral-400 text-white bg-neutral-900/60 hover:bg-neutral-700 px-2.5 py-1 md:px-3 rounded-sm text-sm font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-white transition-colors js_section_tab" href="#insights-anchor">Insights</a>
        <a id="section-tab-explore" class="inline-flex items-center border border-neutral-400 text-white bg-neutral-900/60 hover:bg-neutral-700 px-2.5 py-1 md:px-3 rounded-sm text-sm font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-white transition-colors js_section_tab" href="#explore-anchor">Explore</a>
        <a id="section-tab-actions" class="inline-flex items-center border border-neutral-400 text-white bg-neutral-900/60 hover:bg-neutral-700 px-2.5 py-1 md:px-3 rounded-sm text-sm font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-white transition-colors js_section_tab" href="#actions-anchor">Actions</a>
      </div>

    </section>
  </nav>
  {% endif %}
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const menuToggle = document.getElementById('menu-toggle');
    const menuToggleLabel = document.getElementById('menu-toggle-label');
    const mobileMenu = document.getElementById('mobile-menu');

    menuToggle.addEventListener('click', function () {
      const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
      const nextExpanded = !isExpanded;
      menuToggle.setAttribute('aria-expanded', String(nextExpanded));
      if (menuToggleLabel) menuToggleLabel.textContent = nextExpanded ? 'Close menu' : 'Open menu';

      if (!isExpanded) {
        mobileMenu.classList.remove('hidden');
      } else {
        mobileMenu.classList.add('hidden');
      }
    });
  });
</script>
