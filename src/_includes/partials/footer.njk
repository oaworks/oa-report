<footer class="bg-neutral-900 text-white md:flex md:justify-between p-8 md:px-8" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Site footer</h2>
  <a href="/" class="block">
    {% set logo_size = 'w-20 md:w-24 lg:w-32' %}
    {% include 'partials/app-name.njk' %}
  </a>
  <nav class="mt-8 md:mt-0 md:flex" aria-labelledby="footer-nav-heading">
    <h3 id="footer-nav-heading" class="sr-only">Footer links</h3>
    <ul class="flex flex-col items-start gap-2 text-left md:flex-row md:items-center md:gap-12 md:justify-center">
      {% for item in nav_footer %}
      <li>
        <a href="{{ item.url }}" {% if item.ext %}target="_blank" rel="noopener"{% endif %} class="inline-flex min-h-[44px] items-center rounded-md px-0 py-0 text-base lg:text-lg transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-carnation-400 focus-visible:ring-offset-2">{{ item.label }}</a>
      </li>
      {% endfor %}
      {% if org._source.name %}
      <li>
        <a href="?logout" data-auth="in" id="logout" class="inline-flex min-h-[44px] items-center rounded-md px-0 py-0 text-base lg:text-lg font-semibold transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-carnation-400 focus-visible:ring-offset-2">Log out <span aria-hidden="true" class="ml-1">&rarr;</span></a>
      </li>
      <li>
        <button data-auth="out" data-modal-title="Log in to access this OA.Report" data-modal-content="<div class='text-center'><p class='mb-2'>If you work for <strong>{{ org._source.name }}</strong>, search your inbox for an email titled <br><span class='highlight font-normal'>&ldquo;OA.Report login link&rdquo;</span><br> to access your report.</p><p class='mb-4'>If you can't find it, please <a href='mailto:joe@oa.works?subject=I%20can't%20find%20my%20OA.Report%20login%20link' class='underline underline-offset-2 decoration-1'>contact our helpdesk</a>.</p><hr><p class='pt-4'><small class='text-xs font-normal'>Find out more about <a href='https://about.oa.report/docs/user-accounts' target='_blank' rel='noopener' class='underline underline-offset-2 decoration-1'>OA.Report user accounts</a>.</small></p></div>" id="login" class="inline-flex min-h-[44px] items-center rounded-md px-0 py-0 text-base lg:text-lg font-semibold transition duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-carnation-400 focus-visible:ring-offset-2">Log in <span aria-hidden="true" class="ml-1">&larr;</span></button>
      </li>
      {% endif %}
    </ul>
  </nav>
</footer>

{# Load JS for org report pages only #}
{% if org._source.name %}
<script>
  const org = ("{{ org._source.objectID | urlencode }}"),
        orgSlug = ("{{ org._source.objectID | slug }}"),
        orgName = ("{{ org._source.name|safe }}"),
        orgPolicyUrl = ("{{ org._source.policy.url }}"),
        orgPolicyCompliance = ("{{ org._source.policy.help_text.compliant }}"),
        orgPolicyCoverage = ("{{ org._source.policy.help_text.covered_by_policy }}");
</script>
{% endif %}

{# Load homepage-specific JS #}
{% if page.url == '/' %}
<script src="/js/sal.js"></script> {# Scroll animations #}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    sal();
  });
</script>

<noscript>
  <style type="text/css">
    [data-sal|='fade'] {
      opacity: 1;
    }

    [data-sal|='slide'],
    [data-sal|='zoom'] {
      opacity: 1;
      transform: none;
    }

    [data-sal|='flip'] {
      transform: none;
    }
  </style>
</noscript>
{% endif %}

{# Load font #}

{% block extra_footer %}{% endblock %}
