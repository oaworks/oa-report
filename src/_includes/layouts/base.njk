<!doctype html>
<html class="no-js scroll-smooth" lang="en">
  {% include 'partials/head.njk' %}
  <body
    class="flex flex-col min-h-screen justify-between antialiased text-neutral-900 tracking-wide leading-relaxed text-xs md:text-sm lg:text-lg"
    data-api-host-orgs="{{ env.ELEVENTY_API_HOST_ORGS }}"
    data-api-host-works="{{ env.ELEVENTY_API_HOST_WORKS }}">
    {# General alert, managed via /_data/site.js #}
    {% if site.banner and page.url != '/' %}
    <section class="js-top-banner p-4 bg-carnation-700 text-white font-medium text-center text-xs [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-white [&_a]:font-semibold">
      <p>{{ site.banner | safe }}</p>
    </section>
    {% endif %}
    {# Per-report alert, managed via /report/orgs #}
    {% if org and org._source and org._source.alert_text %}
    <section class="js-top-banner p-4 bg-carnation-800 text-white font-medium text-center text-xs [&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-white [&_a]:font-semibold">
      <p>{{ org._source.alert_text | safe }}</p>
    </section>
    {% endif %}
    {% if page.url != '/' %}
    <p id="js-alert" class="sticky top-0 z-[60] hidden p-4 bg-carnation-500 text-white font-medium text-center text-xs"></p>
    {% endif %}
    {% if env_badge.label %}
      <div class="fixed left-0 bottom-6 z-[70]">
        <div class="flex flex-col gap-1 p-2 bg-carnation-700 text-white shadow-lg text-xs font-semibold">
          <span>{{ env_badge.label }}</span>
          {% if env_badge.api %}<span>{{ env_badge.api | safe }}</span>{% endif %}
        </div>
      </div>
    {% endif %}
    {% if hideBaseHeader != true %}
      {% include 'partials/header.njk' %}
    {% endif %}
    {% block content %}{% endblock %}
    {{ content | safe }}
    {% include 'partials/footer.njk' %}

    <noscript><img src="https://queue.simpleanalyticscdn.com/noscript.gif" alt="" referrerpolicy="no-referrer-when-downgrade" /></noscript>
  </body>
</html>
